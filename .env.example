# MATOS — variables de entorno
# Copia a .env y rellena los secretos.
# El fichero .env está en .gitignore — no comitear.

# ---- Core ----
MATOS_ENV=dev                                       # dev | prod
MATOS_DOMAIN=matos.local                            # dominio servido por Caddy
MATOS_ARCHIVE_PATH=/data/archivo                    # ruta al archivo dentro del contenedor
MATOS_INDEX_PATH=/data/index/matos.db               # ruta al SQLite de índice

# Upstream del frontend para Caddy. Se sobrescribe por compose:
#   dev  → frontend:5173 (vite dev server)
#   prod → frontend:80   (caddy interno sirviendo estáticos)
FRONTEND_UPSTREAM=frontend:5173

# ---- Spotify (fase 13) ----
# Crear app en https://developer.spotify.com/dashboard
# Redirect URI debe coincidir EXACTAMENTE con la registrada.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://matos.local/api/integrations/spotify/callback

# ---- YouTube (fase 14, opcional) ----
# Sin clave: se usa oEmbed (limitado, sin duración).
# Con clave: YouTube Data API v3 (10k unidades/día gratis).
# Crear en https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ---- Registry (fase 18) ----
# Para `make release`. Ejemplos:
#   ghcr.io/<usuario>
#   docker.io/<usuario>
REGISTRY=
